#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

# 根据你的实际路径修改这两个变量
EASYTIER_BIN="/data/easytier/easytier-core"
CONFIG_FILE="/data/easytier/config.toml"

start_service() {
    procd_open_instance
    procd_set_param command "$EASYTIER_BIN" -c "$CONFIG_FILE"
    procd_set_param respawn  # auto restart on ps dead
    procd_set_param stdout 0
    procd_set_param stderr 0
    procd_close_instance
}
